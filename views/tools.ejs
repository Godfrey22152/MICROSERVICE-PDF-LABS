<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDF Labs - Tools</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <header>
        <h1>Welcome to PDF Tools Lab</h1>
        <p>Choose a tool below then watch the application perform the magic</p>
    </header>

    <section class="dashboard">
        <div class="nav-buttons">
            <button id="dashboardBtn">Dashboard</button>
            <button id="toolsBtn" class="active">Tools</button>
            <button id="settingsBtn">Settings</button>
            <button id="profileBtn">Profile</button>
            <button id="logoutBtn">Logout</button>
        </div>
    </section>

    <section class="features">
        <a class="feature-card" id="pdfToAudioBtn" href="#">
            <img src="/images/audio.png" alt="PDF to Audio">
            <h2>PDF to Audio Conversion</h2>
            <p>Convert PDFs into audio files for easy listening.</p>
        </a>
        <a class="feature-card" id="pdfToImageBtn" href="#">
            <img src="/images/image.png" alt="PDF to Image">
            <h2>PDF to Image Conversion</h2>
            <p>Transform PDF pages into high-quality images.</p>
        </a>
        <a class="feature-card" id="pdfCompressorBtn" href="#">
            <img src="/images/pdf-compressor.png" alt="PDF Compressor">
            <h2>PDF Compressor</h2>
            <p>Reduce PDF file size while maintaining quality.</p>
        </a>
        <a class="feature-card" id="pdfToWordBtn" href="#">
            <img src="/images/pdf-to-word.png" alt="PDF to Word">
            <h2>PDF to Word Conversion</h2>
            <p>Convert PDFs into editable Word documents.</p>
        </a>
        <a class="feature-card" id="wordToPdfBtn" href="#">
            <img src="/images/word-to-pdf.png" alt="Word to PDF">
            <h2>Word to PDF Conversion</h2>
            <p>Create PDFs from Word documents.</p>
        </a>
        <a class="feature-card" id="editPdfBtn" href="#">
            <img src="/images/edit-pdf.png" alt="Edit PDF">
            <h2>Edit PDF</h2>
            <p>Rotate, watermark, merge, split, protect or unlock your PDF files.</p>
        </a>
        <a class="feature-card" id="imageToPdfBtn" href="#">
            <img src="/images/image-to-pdf.png" alt="Image to PDF">
            <h2>Convert Image to PDF</h2>
            <p>Convert Image to PDF as you like</p>
        </a>
        <a class="feature-card" id="sheetlabBtn" href="#">
            <img src="/images/sheetlab.png" alt="SheetLab PDF to Excel">
            <h2>Excel SheetLab<br>PDF ↔ Excel</h2>
            <p>Convert PDFs to Excel spreadsheets or Excel files to PDF documents.</p>
        </a>
    </section>

    <!-- Toast container -->
    <div id="toast-container"></div>

    <script src="/js/script.js"></script>
</body>
</html>

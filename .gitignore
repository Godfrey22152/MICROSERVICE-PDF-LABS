# =============================================================
# .gitignore — home-service
# =============================================================

# ── Dependencies ──────────────────────────────────────────────
node_modules/
jspm_packages/

# ── Environment & Secrets ─────────────────────────────────────
# NEVER commit real secrets — use .env.example for reference
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.crt
secrets/

# ── Config Overrides (only default.json is safe to commit) ────
config/local.json
config/local-*.json
config/production.json

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.seed
*.pid.lock

# ── Runtime / Cache ───────────────────────────────────────────
.cache/
.npm/
.yarn/
.node_repl_history
tmp/
temp/

# ── Build Artifacts ───────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo

# ── Test & Coverage ───────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── OS Artifacts ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Editor & IDE ──────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace
.editorconfig

# ── Docker (compose file lives in root repo, not here) ────────
docker-compose*.yml
.dockerignore

# ── Optional: lock file (remove this line if you want to commit it) ──
# package-lock.json

# ── Linting & Diagnostic ──────────────────────────────────────
.eslintcache
.stylelintcache
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
